# OIDC Provider Configuration
VITE_OIDC_ISSUER=https://localhost:44324
VITE_OIDC_CLIENT_ID=GeoTrees_React

# Application URLs
VITE_BASE_URL=http://localhost:3000
VITE_OIDC_REDIRECT_URI=http://localhost:3000/auth/callback

# Session Configuration
# REQUIRED. At least 32 high-entropy characters. Generate one with e.g.
#   openssl rand -base64 48
# The server refuses to start with this placeholder value.
VITE_SESSION_SECRET=replace-me-with-a-real-32+-character-secret-please

# API Configuration
VITE_API_BASE_URL=https://localhost:44324
VITE_API_PROXY_PATH=/api/proxy
VITE_OPENAPI_SPEC_URL=https://localhost:44324/swagger/v1/swagger.json
VITE_APP_NAME=geo-trees
VITE_APP_VERSION=v1
VITE_OIDC_SCOPES="openid profile email offline_access GeoTrees"
NODE_TLS_REJECT_UNAUTHORIZED=0